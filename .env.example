# ── Exchange Rate API ──────────────────────────────────────────────
# Free tier: https://app.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=your_exchangerate_api_key_here

# ── Oil Price (Brent) ─────────────────────────────────────────────
# Free tier: https://www.eia.gov/opendata/  or  https://api.api-ninjas.com/
EIA_API_KEY=your_eia_api_key_here

# ── USD Index / DXY ───────────────────────────────────────────────
# Provided via Alpha Vantage (free): https://www.alphavantage.co/
ALPHA_VANTAGE_API_KEY=your_alphavantage_api_key_here

# ── Telegram Bot ──────────────────────────────────────────────────
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Wise Fee ──────────────────────────────────────────────────────
# Default conversion fee percentage (e.g. 0.5 = 0.5%)
WISE_FEE_PERCENT=0.5

# ── Alert Threshold ───────────────────────────────────────────────
# Minimum signal score to trigger an alert (absolute value, e.g. 2)
ALERT_THRESHOLD=2

# ── Server ────────────────────────────────────────────────────────
PORT=3000
